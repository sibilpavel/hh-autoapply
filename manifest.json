{
  "manifest_version": 3,
  "name": "HH Auto Response",
  "version": "1.0",

  "permissions": [
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "https://hh.ru/*"
  ],

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["https://*.hh.ru/*", "https://hh.ru/*"],
      "js": ["content.js"]
    }
  ]
}