{
  "manifest_version": 3,

  "name": "HH Auto Response",

  "version": "1.0.0",

  "permissions": [
    "storage",
    "tabs"
  ],

  "host_permissions": [
    "https://hh.ru/*"
  ],

  "action": {
    "default_popup": "src/popup/popup.html"
  },

  "content_scripts": [
    {
      "matches": ["https://*.hh.ru/*"],
      "js": ["content.js"]
    }
  ]
}